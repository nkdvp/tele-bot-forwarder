BOT_TOKEN=your_bot_token_here
HEALTH_PORT=8080

# --- DB mode ---
# false: legacy file mode
# true: sqlite + web admin mode
USE_DB_CONFIG=false
DB_PATH=data/forwarder.db

# --- Web admin ---
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8090
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# --- Backups ---
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_SECONDS=86400
